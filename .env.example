# PostgreSQL (obligatoire en prod / Railway). En local : Docker ou Postgres installé.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bllabs?schema=public"
# Secret pour JWT (générer : openssl rand -base64 32)
JWT_SECRET="change-me-in-production-use-openssl-rand-base64-32"
# Port (Railway injecte PORT automatiquement)
PORT="3000"
# Origine(s) CORS autorisées, séparées par des virgules (ex. URL Vercel)
CORS_ORIGIN="http://localhost:4200"
